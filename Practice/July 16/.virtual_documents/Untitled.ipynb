plt.legend (["Sachin" , "kohli"])
plt.show ()








plt.plot (years , runs , "o:")
plt.plot () 





plt.plot (years , runs ,"k") 
plt.plot ()





plt.plot (years , runs , color = "black" , linestyle = "--" , label = "Sachin" ) 
