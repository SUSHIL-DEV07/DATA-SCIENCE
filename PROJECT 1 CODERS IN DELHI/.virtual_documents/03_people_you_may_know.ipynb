def find_people_you_may_know(user_id, data):
    user_friends = {}
    for user in data["users"]:
        user_friends[user["id"]] = set(user["friends"])
    
    if user_id not in user_friends:
        return []
    
    direct_friends = user_friends[user_id]
    suggestions = {}
    
    for friend in direct_friends:
        # For all friends of friend
        for mutual in user_friends[friend]:
            # If mutual id is not the same user and not already a direct friend of user
            if mutual != user_id and mutual not in direct_friends:
                # Count mutual friends
                suggestions[mutual] = suggestions.get(mutual, 0) + 1
    
    sorted_suggestions = sorted(suggestions.items(), key=lambda x: x[1], reverse=True)
    return [user_id for user_id, _ in sorted_suggestions]
 


import json 

def load_file (filename) :
    with open (filename) as F :
        return json.load (F) 

def people_you_may_know (id , data) :

    All_friend = {}

    for user in data ["users"] :
        All_friend [user['id']] = user ['friends']
        # {1: [2, 3], 2: [1, 4], 3: [1], 4: [2]}

    if id not in All_friend : 
        return []
        # if pass id not a valid id

    user_friend = All_friend [id]
    # [2, 3]

    suggession = {}

    for F in user_friend :
        # [2, 3]

        for mutual in All_friend [F] :
            # 1 
            # 4 
            # 1 
            if mutual != id and mutual not in user_friend :
                suggession [mutual] = suggession.get (mutual, 0 ) + 1
                # {4: 1}

    sorted_sug = sorted (suggession.items() , key = lambda x : x[1] , reverse = True )
    return [id for id , _ in sorted_sug ]

                
data = load_file ("messive_data.json")   
userid = 15
ref = people_you_may_know (userid , data)
print (f"User : {userid} Recomdatation : {ref} ")





